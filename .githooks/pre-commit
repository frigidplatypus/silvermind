#!/usr/bin/env bash
set -euo pipefail

rebuild_if_stale() {
  local dist_file="$1"
  local dist_dir="$2"
  local build_cmd="$3"

  if [ ! -f "$dist_file" ]; then
    echo "$dist_dir missing. Running $build_cmd..."
    $build_cmd
    git add "$dist_dir"
    return
  fi

  STALE=$(find src/ frontend/ -newer "$dist_file" -name '*.svelte' -o -name '*.ts' -o -name '*.css' -o -name '*.js' 2>/dev/null | head -1)

  if [ -n "$STALE" ]; then
    echo "Frontend source changed. Rebuilding $build_cmd..."
    $build_cmd
    git add "$dist_dir"
  fi
}

rebuild_if_stale "desktop/frontend/dist/index.html" "desktop/frontend/dist/" "pnpm build:desktop"
rebuild_if_stale "frontend/dist/index.html" "frontend/dist/" "pnpm build:web"
