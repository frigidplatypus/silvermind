{
  "name": "silvermind",
  "version": "0.1.0",
  "description": "Silvermind — a native iOS task management app powered by sbtask",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dev:desktop": "vite --config vite.config.desktop.ts",
    "build:desktop": "vite build --config vite.config.desktop.ts",
    "build:web": "vite build --config frontend/vite.config.web.ts",
    "preview": "vite preview",
    "cap:sync": "cap sync ios",
    "cap:sync:android": "cap sync android",
    "cap:open": "cap open ios",
    "cap:open:android": "cap open android",
    "sbtask:fetch": "bash scripts/fetch-sbtask.sh"
  },
  "dependencies": {
    "@capacitor/core": "^6.1.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "dompurify": "^3.2.0",
    "feather-icons": "^4.29.2",
    "marked": "^18.0.0",
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.1.0",
    "@capacitor/ios": "^6.1.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/node": "^22.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^2.45.0",
    "prettier": "^3.3.0",
    "prettier-plugin-svelte": "^3.2.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0"
  }
}
